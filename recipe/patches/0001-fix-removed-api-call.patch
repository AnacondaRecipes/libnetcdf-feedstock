From bc7afcc9f1190126bdd1d1143e716e053236ed5d Mon Sep 17 00:00:00 2001
From: Ivan Iziumov <iiziumov@anaconda.com>
Date: Fri, 20 Feb 2026 16:13:02 +0100
Subject: [PATCH] fix removed api call

---
 libhdf5/H5FDhttp.c         | 10 ++++------
 libhdf5/H5FDhttp.h         |  2 +-
 nczarr_test/ncdumpchunks.c |  2 +-
 3 files changed, 6 insertions(+), 8 deletions(-)

diff --git a/libhdf5/H5FDhttp.c b/libhdf5/H5FDhttp.c
index 917c73a11..99043f8fa 100644
--- a/libhdf5/H5FDhttp.c
+++ b/libhdf5/H5FDhttp.c
@@ -49,12 +49,10 @@
 Define a simple #ifdef test for the version of H5FD_class_t we are using 
 */
 
-#if H5_VERS_MAJOR == 1
-#if H5_VERS_MINOR < 10
-#define H5FDCLASS1 1
-#endif
-#else
-#error "Cannot determine version of H5FD_class_t"
+#if H5_VERS_MAJOR == 1 
+    #if H5_VERS_MINOR < 10
+        #define H5FDCLASS1 1
+    #endif
 #endif
 
 #ifdef H5_HAVE_WIN32_API
diff --git a/libhdf5/H5FDhttp.h b/libhdf5/H5FDhttp.h
index 376609e9f..ce7c05759 100644
--- a/libhdf5/H5FDhttp.h
+++ b/libhdf5/H5FDhttp.h
@@ -31,7 +31,7 @@
 
 #if H5_VERSION_GE(1,13,2)
 #define H5_VFD_HTTP     ((H5FD_class_value_t)(514))
-#define H5FD_HTTP	(H5FDperform_init(H5FD_http_init))
+#define H5FD_HTTP (H5OPEN H5FD_http_init())
 #else
 #define H5FD_HTTP	(H5FD_http_init())
 #endif
diff --git a/nczarr_test/ncdumpchunks.c b/nczarr_test/ncdumpchunks.c
index 758314aa2..837cfa26f 100644
--- a/nczarr_test/ncdumpchunks.c
+++ b/nczarr_test/ncdumpchunks.c
@@ -412,7 +412,7 @@ dump(Format* format)
 #ifdef H5
 	case NC_FORMATX_NC_HDF5: {
 	    for(i=0;i<format->rank;i++) hoffset[i] = (hsize_t)offset[i];
-	    if(H5Dread_chunk(datasetid, dxpl_id, hoffset, &filter_mask, chunkdata) < 0)
+	    if(H5Dread_chunk1(datasetid, dxpl_id, hoffset, &filter_mask, chunkdata) < 0)
 	        holechunk = 1;
 	} break;
 #endif
-- 
2.51.0

